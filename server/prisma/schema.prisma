datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName          String    @db.VarChar(255)
  ownerName             String    @db.VarChar(255)
  email                 String    @db.VarChar(255)
  phone                 String?   @db.VarChar(20)
  passwordHash          String?   @db.Text
  logoUrl               String?   @db.Text
  signatureUrl          String?   @db.Text
  address               String?   @db.Text
  businessPhone         String?   @db.VarChar(20)
  businessEmail         String?   @db.VarChar(255)
  gstin                 String?   @db.VarChar(50)
  state                 String?   @db.VarChar(100)
  vpa                   String?   @db.VarChar(255)
  isActive              Boolean?  @default(true)
  language              String?   @default("gu") @db.VarChar(10)
  plan                  String?   @default("starter") @db.VarChar(50)
  status                String?   @default("active") @db.VarChar(20)
  approvedAt            DateTime? @db.Timestamp(6)
  approvedBy            String?   @db.VarChar(100)
  rejectionReason       String?   @db.Text
  subscriptionExpiresAt DateTime? @db.Timestamp(6)
  otpCode               String?   @db.VarChar(10)
  otpExpiresAt          DateTime? @db.Timestamp(6)
  bankDetails           String?   @db.Text
  invoiceTerms          String?   @db.Text
  requestedPlan         String?   @db.VarChar(50)
  planRequestStatus     String?   @default("none") @db.VarChar(20)
  trialWarning10Sent    Boolean?  @default(false)
  trialWarning14Sent    Boolean?  @default(false)
  paidWarning5Sent      Boolean?  @default(false)
  paidWarning1Sent      Boolean?  @default(false)
  createdAt             DateTime  @default(now()) @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @db.Timestamp(6)

  customers       Customer[]
  suppliers       Supplier[]
  ledgerEntries   LedgerEntry[]
  invoices        Invoice[]
  purchaseBills   PurchaseBill[]
  paymentReceipts PaymentReceipt[]
  activityLogs    ActivityLog[]
  products        Product[]
  creditNotes     CreditNote[]
  debitNotes      DebitNote[]
}

model Customer {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String   @db.Uuid
  name            String   @db.VarChar(255)
  shopName        String?  @db.VarChar(255)
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  billingAddress  String?  @db.Text
  shippingAddress String?  @db.Text
  gstin           String?  @db.VarChar(50)
  state           String?  @db.VarChar(100)
  creditLimit     Decimal? @default(0.00) @db.Decimal(12, 2)
  openingBalance  Decimal? @default(0.00) @db.Decimal(12, 2)
  isDeleted       Boolean? @default(false)
  shareId         String?  @unique @db.VarChar(50)
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @db.Timestamp(6)

  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer_shop")
  ledgerEntries   LedgerEntry[]
  invoices        Invoice[]
  paymentReceipts PaymentReceipt[]
  creditNotes     CreditNote[]
}

model Supplier {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String   @db.Uuid
  name            String   @db.VarChar(255)
  shopName        String?  @db.VarChar(255)
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  billingAddress  String?  @db.Text
  shippingAddress String?  @db.Text
  gstin           String?  @db.VarChar(50)
  state           String?  @db.VarChar(100)
  creditLimit     Decimal? @default(0.00) @db.Decimal(12, 2)
  openingBalance  Decimal? @default(0.00) @db.Decimal(12, 2)
  isDeleted       Boolean? @default(false)
  shareId         String?  @unique @db.VarChar(50)
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @db.Timestamp(6)

  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_supplier_shop")
  ledgerEntries   LedgerEntry[]
  purchaseBills   PurchaseBill[]
  paymentReceipts PaymentReceipt[]
  debitNotes      DebitNote[]
}

model LedgerEntry {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId         String    @db.Uuid
  customerId     String?   @db.Uuid
  supplierId     String?   @db.Uuid
  date           DateTime  @default(now()) @db.Timestamp(6)
  particulars    String    @db.VarChar(500)
  type           String    @db.VarChar(20)
  amount         Decimal   @db.Decimal(12, 2)
  runningBalance Decimal?  @default(0.00) @db.Decimal(12, 2)
  isEdited       Boolean?  @default(false)
  lastEditedAt   DateTime? @db.Timestamp(6)
  referenceId    String?   @db.VarChar(100)

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ledger_shop")
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_ledger_customer")
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_ledger_supplier")
}

model Invoice {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNo      String   @db.VarChar(100)
  shopId         String   @db.Uuid
  customerId     String   @db.Uuid
  date           DateTime @default(now()) @db.Timestamp(6)
  itemsJson      Json
  subTotal       Decimal  @db.Decimal(12, 2)
  discount       Decimal? @default(0.00) @db.Decimal(12, 2)
  taxAmount      Decimal? @default(0.00) @db.Decimal(12, 2)
  miscCharges    Decimal? @default(0.00) @db.Decimal(12, 2)
  taxRate        Decimal? @default(18.00) @db.Decimal(5, 2)
  grandTotal     Decimal  @db.Decimal(12, 2)
  description    String?  @db.Text
  attachedImgUrl String?  @db.Text
  advancePayment Decimal? @default(0.00) @db.Decimal(12, 2)
  paymentMode    String?  @default("CASH") @db.VarChar(50)
  isEdited       Boolean? @default(false)
  createdAt      DateTime @default(now()) @db.Timestamp(6)

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invoice_shop")
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invoice_customer")
  creditNotes CreditNote[]
}

model PurchaseBill {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billNo         String?  @db.VarChar(100)
  shopId         String   @db.Uuid
  supplierId     String   @db.Uuid
  date           DateTime @default(now()) @db.Timestamp(6)
  itemsJson      Json?
  attachedImgUrl String?  @db.Text
  slipDetails    String?  @db.VarChar(255)
  totalAmount    Decimal  @db.Decimal(12, 2)
  advancePayment Decimal? @default(0.00) @db.Decimal(12, 2)
  paymentMode    String?  @default("CASH") @db.VarChar(50)
  isEdited       Boolean? @default(false)
  createdAt      DateTime @default(now()) @db.Timestamp(6)

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pbill_shop")
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pbill_supplier")
  debitNotes DebitNote[]
}

model PaymentReceipt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptNo   String   @db.VarChar(100)
  shopId      String   @db.Uuid
  customerId  String?  @db.Uuid
  supplierId  String?  @db.Uuid
  date        DateTime @default(now()) @db.Timestamp(6)
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String?  @default("CASH") @db.VarChar(50)
  remark      String?  @db.VarChar(550)
  isEdited    Boolean? @default(false)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  invoiceId   String?  @db.Uuid
  purchaseBillId String? @db.Uuid

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_receipt_shop")
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_receipt_customer")
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_receipt_supplier")
}


model Plan {
  id                 String   @id @db.VarChar(50)
  name               String   @db.VarChar(100)
  price              Decimal  @default(0.00) @db.Decimal(12, 2)
  billingCycle       String   @default("monthly") @db.VarChar(20)
  allowedTabs        Json
  features           Json
  requiresApproval   Boolean  @default(true)
  allowMultiBusiness Boolean  @default(false)
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @default(now()) @db.Timestamp(6)
}

model ActivityLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String?  @db.Uuid
  type      String   @db.VarChar(100)
  actor     String   @db.VarChar(255)
  target    String   @db.VarChar(500)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

model AdminUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String   @unique @db.VarChar(100)
  passwordHash String   @db.Text
  token        String?  @db.Text
  supportPhone String?  @default("+91 97732 72749") @db.VarChar(50)
  supportEmail String?  @default("support.gallamitra@gmail.com") @db.VarChar(255)
  backendUrl   String?  @db.Text
  frontendUrl  String?  @db.Text
  adminUrl     String?  @db.Text
  smtpHost     String?  @db.VarChar(255)
  smtpPort     Int?     @default(587)
  smtpSecure   Boolean? @default(false)
  smtpUser     String?  @db.VarChar(255)
  smtpPass     String?  @db.Text
  smtpFrom     String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)
}

model EmailQueue {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  toEmail     String    @db.VarChar(255)
  subject     String    @db.VarChar(255)
  body        String    @db.Text
  status      String?   @default("pending") @db.VarChar(50)
  error       String?   @db.Text
  attempts    Int?      @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  processedAt DateTime? @db.Timestamp(6)
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId           String   @db.Uuid
  name             String   @db.VarChar(255)
  price            Decimal? @default(0.00) @db.Decimal(12, 2)
  description      String?  @db.Text
  hsnCode          String?  @db.VarChar(50)
  sacCode          String?  @db.VarChar(50)
  uqc              String?  @default("NOS") @db.VarChar(20)
  currentStock     Decimal? @default(0.00) @db.Decimal(12, 2)
  minStockLevel    Decimal? @default(0.00) @db.Decimal(12, 2)
  averageCostPrice Decimal? @default(0.00) @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @db.Timestamp(6)

  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_shop")
}

model CreditNote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteNo          String   @db.VarChar(100)
  shopId          String   @db.Uuid
  customerId      String   @db.Uuid
  invoiceId       String?  @db.Uuid
  date            DateTime @default(now()) @db.Timestamp(6)
  invoiceDate     DateTime? @db.Timestamp(6)
  type            String   @db.VarChar(50)  // "RETURN" or "RATE_DIFFERENCE"
  productId       String?  @db.Uuid
  productName     String?  @db.VarChar(255)
  qty             Decimal? @db.Decimal(12, 2)
  price           Decimal? @db.Decimal(12, 2)
  amount          Decimal  @db.Decimal(12, 2)
  remark          String?  @db.Text
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_creditnote_shop")
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_creditnote_customer")
  invoice         Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_creditnote_invoice")
}

model DebitNote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteNo          String   @db.VarChar(100)
  shopId          String   @db.Uuid
  supplierId      String   @db.Uuid
  purchaseBillId  String?  @db.Uuid
  date            DateTime @default(now()) @db.Timestamp(6)
  invoiceDate     DateTime? @db.Timestamp(6)
  type            String   @db.VarChar(50)  // "RETURN" or "RATE_DIFFERENCE"
  productId       String?  @db.Uuid
  productName     String?  @db.VarChar(255)
  qty             Decimal? @db.Decimal(12, 2)
  price           Decimal? @db.Decimal(12, 2)
  amount          Decimal  @db.Decimal(12, 2)
  remark          String?  @db.Text
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  shop            Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_debitnote_shop")
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_debitnote_supplier")
  purchaseBill    PurchaseBill? @relation(fields: [purchaseBillId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_debitnote_purchasebill")
}
